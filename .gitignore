# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# local browser automation profiles
.local/
qbank-tools/.local/

# localization pipeline bulk/generated artifacts
**/screenshots/
imports/*/batch-*/screenshots/
imports/*/batch-*/extraction-report.json
imports/*/batch-*/intake.json
imports/*/batch-*/matched.json
imports/*/batch-*/review-needed.json
imports/*/batch-*/unresolved.json
qbank-tools/generated/staging/*.preview.json
qbank-tools/generated/staging/*.merge-dry-run.json
qbank-tools/generated/staging/*.template.json
qbank-tools/generated/staging/*diagnostics*/
qbank-tools/generated/archive/
qbank-tools/generated/archive/**
!qbank-tools/history/
!qbank-tools/history/decisions/
!qbank-tools/history/decisions/**
!qbank-tools/generated/staging/*workbench-decisions.json
!qbank-tools/generated/reports/*ship-readiness-report.json
!qbank-tools/generated/reports/*ship-readiness-report.md
!qbank-tools/generated/reports/full-batch-merge-review-*.json
!qbank-tools/generated/reports/full-batch-merge-review-*.md

# typescript
*.tsbuildinfo
next-env.d.ts
